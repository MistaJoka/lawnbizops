{
  "name": "lawnbizops",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:mutation": "stryker run",
    "bundle:check": "node scripts/bundle-budget.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:demo": "playwright test --config playwright.demo.config.ts",
    "dev:demo": "VITE_DEMO=1 vite",
    "verify": "npm run lint && npm run format:check && npm run typecheck && npm run test && node scripts/check-migrations.mjs && node scripts/qa-registry-check.mjs && node scripts/check-no-emoji-ui.mjs && npm run build && npm run bundle:check"
  },
  "dependencies": {
    "@fontsource/archivo-narrow": "^5.2.8",
    "@fontsource/atkinson-hyperlegible-next": "^5.2.7",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@react-pdf/renderer": "^4.5.1",
    "@supabase/supabase-js": "^2.108.1",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-persist-client": "^5.101.0",
    "@tanstack/react-router": "^1.170.15",
    "dexie": "^4.4.3",
    "dexie-react-hooks": "^4.4.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.26.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@sentry/react": "^10.57.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/router-plugin": "^1.168.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.2.5",
    "fast-check": "^4.8.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "supabase": "^2.105.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "qs": "^6.15.3"
  }
}
