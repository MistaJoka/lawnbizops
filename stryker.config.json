{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "vitest",
  "coverageAnalysis": "perTest",
  "mutate": [
    "src/lib/route.ts",
    "src/lib/csv.ts",
    "src/lib/dates.ts",
    "src/lib/format.ts",
    "src/lib/recurrence.ts",
    "src/features/board/hooks.ts",
    "src/features/invoices/hooks.ts",
    "src/features/estimates/hooks.ts"
  ],
  "reporters": ["clear-text", "progress"],
  "clearTextReporter": { "allowColor": false },
  "thresholds": { "high": 85, "low": 70, "break": 55 }
}
